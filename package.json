{
  "name": "play.flix.dev",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "ansi-to-react": "^6.2.6",
    "bootstrap": "^5.3.2",
    "lz-string": "^1.5.0",
    "pretty-ms": "^8.0.0",
    "react": "^18.2.0",
    "react-ace": "^10.1.0",
    "react-dom": "^18.2.0",
    "react-spinners": "^0.13.8",
    "reactstrap": "^9.2.0",
    "reconnecting-websocket": "^4.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "vite": "^6.2.0"
  },
  "scripts": {
    "build-script": "node build-scripts/main.mjs",
    "dev": "npm run build-script && vite",
    "build": "npm run build-script && vite build",
    "preview": "vite preview"
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es2021": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:react/recommended",
      "plugin:react/jsx-runtime",
      "plugin:react-hooks/recommended"
    ],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module",
      "ecmaFeatures": {
        "jsx": true
      }
    },
    "settings": {
      "react": {
        "version": "detect"
      }
    },
    "rules": {
      "react/prop-types": "off"
    }
  }
}
